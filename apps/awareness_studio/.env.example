# Awareness Studio — environment variables
# Copy to .env and fill in values. Everything has a safe default for offline use.
# See docs/CONFIG.md for full reference.

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic                          # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...                    # required for Anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=sk-...                         # required for OpenAI
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1     # override for proxies
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ── Index backend ─────────────────────────────────────────────────────────────
INDEX_BACKEND=bm25                              # bm25 (offline) | embedding
EMBEDDING_PROVIDER=local_stub                  # local_stub (offline) | openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=64                              # 64 for stub, 1536 for openai
# NOTION_EXPORT_DIR=/path/to/exports            # default: inputs/notion_export/

# ── Tools (external search) ───────────────────────────────────────────────────
TOOLS_ENABLED=false                             # true to enable PubMed/Linear routing
# TOOLS_ALLOWLIST=pubmed_search,biorxiv_search  # empty = all tools allowed
# TOOLS_MAX_CALLS_PER_REQUEST=1
# LINEAR_API_KEY=lin_api_...
# PUBMED_API_KEY=...                            # optional; improves rate limits

# ── Authentication (write endpoint gate) ─────────────────────────────────────
AUTH_ENABLED=false                              # true to require X-Awareness-Key header
# AUTH_API_KEY=your-secret-key

# ── Airtable Ops Mirror ───────────────────────────────────────────────────────
AIRTABLE_ENABLED=false                          # true to enable Airtable writes
# AIRTABLE_API_KEY=patXXXXXXXXXXXXXX           # Personal Access Token
# AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX           # Base ID from URL

# ── Web server ────────────────────────────────────────────────────────────────
# PORT=8000                                     # used by Replit
# CORS_ALLOW_ORIGINS=*                          # or comma-separated origins

# ── Prompt optimization ───────────────────────────────────────────────────────
# PROMPT_OPTIMIZER=none                         # none | dspy_stub
